# ═══════════════════════════════════════════════════════
# Orchestrator Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (for LLM-augmented pipeline steps) ────────
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini
# OPENAI_BASE_URL=  # optional, for custom endpoints

# ── Orchestrator defaults ─────────────────────────────
ORCHESTRATOR_LOG_LEVEL=INFO
ORCHESTRATOR_DEFAULT_BATCH_SIZE=100
ORCHESTRATOR_MAX_RETRIES=3
ORCHESTRATOR_RETRY_DELAY_SECONDS=60

# ── Webhook server ────────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8100
WEBHOOK_SECRET=

# ── Neo4j (passed through to Gold-to-Neo4j pipeline) ─
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_REALTIME_POLL_INTERVAL=5
NEO4J_REALTIME_WORKERS=3           # parallel outbox worker threads
NEO4J_WORKER_BATCH_SIZE=50         # events claimed per worker per poll cycle
NEO4J_WORKER_LOCK_TIMEOUT=300      # seconds before stale locks are reclaimed
NEO4J_REALTIME_AUTOSTART=true      # auto-start workers on API boot

# ── Agentic schema drift ─────────────────────────────
AGENT_LLM_MODEL=gpt-4.1-mini
DRIFT_CONFIDENCE_THRESHOLD=0.85
DRIFT_AGENT_NAME_THRESHOLD=0.7

# ── Alerting: Email (SMTP) ───────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=  # comma-separated

# ── Alerting: GitHub Issues ──────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=  # owner/repo

# ── CrewAI ───────────────────────────────────────────
CREWAI_ENABLED=false

# ── Gold-to-Neo4j pipeline path ──────────────────────
NEO4J_PIPELINE_DIR=Gold-to-Neo4j_with_agentic_checks/Gold-to-Neo4j_services
